# ============================================================
# Siren.ng — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Django core ──────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

DEBUG=False

# Comma-separated. Include your Railway domain and custom domain.
# Example: myapp.railway.app,siren.ng
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (Supabase) ──────────────────────────────────────
# Use the DIRECT CONNECTION URI (port 5432). NEVER the pooler (port 6543).
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Redis (Railway) ──────────────────────────────────────────
# Add a Redis service in Railway and it injects REDIS_URL automatically.
REDIS_URL=redis://default:password@monorail.proxy.rlwy.net:PORT

# ── Celery ───────────────────────────────────────────────────
# Always False in production. True only for local dev without Redis.
CELERY_ALWAYS_EAGER=False

# ── Site URL ─────────────────────────────────────────────────
# Used in WhatsApp message links and Paystack callbacks.
SITE_URL=https://siren.ng

# ── Anthropic (Claude AI) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Twilio (WhatsApp) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Format: whatsapp:+234XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+2349000000000

# ── Paystack ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
SIREN_PAYSTACK_SUBACCOUNT=ACCT_xxxxxxxxxxxxxxxx

# ── Cloudinary (incident photo storage) ─────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── CORS (only needed if frontend is on a separate domain) ───
# CORS_ALLOWED_ORIGINS=https://siren.ng,https://www.siren.ng
